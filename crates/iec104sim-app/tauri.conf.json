{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IEC104Slave",
  "version": "1.1.4",
  "identifier": "com.iec104slave.dev",
  "build": {
    "devUrl": "http://localhost:5176",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../../frontend" },
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "IEC104Slave - IEC 60870-5-104 Simulator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "windows": {
